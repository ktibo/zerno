    <!-- ОКПД2                                                                -->
    <!-- ==================================================================== -->
    <xs:simpleType name="OKPD2CodeType">
        <xs:annotation>
            <xs:documentation>Код ОКПД2</xs:documentation>
        </xs:annotation>

        <xs:restriction base="xs:string">
            <xs:maxLength value="100"/>
        </xs:restriction>
    </xs:simpleType>


    <xs:complexType name="OKPD2Type">
        <xs:annotation>
            <xs:documentation>ОКПД2</xs:documentation>
        </xs:annotation>

        <xs:attribute name="code" use="required" type="tns:OKPD2CodeType">
            <xs:annotation>
                <xs:documentation>Код ОКПД2</xs:documentation>
            </xs:annotation>
        </xs:attribute>

        <xs:attribute name="name">
            <xs:annotation>
                <xs:documentation>Наименование</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="tns:string-200"/>
            </xs:simpleType>
        </xs:attribute>

        <xs:attribute name="startDate">
            <xs:annotation>
                <xs:documentation>Действует с</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:dateTime"/>
            </xs:simpleType>
        </xs:attribute>

        <xs:attribute name="endDate">
            <xs:annotation>
                <xs:documentation>Действует по</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:dateTime"/>
            </xs:simpleType>
        </xs:attribute>

        <xs:attribute name="isGrain">
            <xs:annotation>
                <xs:documentation>Является зерном</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:boolean"/>
            </xs:simpleType>
        </xs:attribute>

        <xs:attribute name="isProduct">
            <xs:annotation>
                <xs:documentation>Является продуктом переработки зерна</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:boolean"/>
            </xs:simpleType>
        </xs:attribute>
    </xs:complexType>


    <xs:element name="OKPD2" type="tns:OKPD2Type"/>


